<% content_for :breadcrumb, "Budget" %>

<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
  <h1 class="snow-page-title" style="margin:0;">Règles budgétaires</h1>
</div>

<%= form_with model: @budget_rule, url: budget_rule_path, method: :patch, class: "snow-form" do |f| %>
  <% if @budget_rule.errors.any? %>
    <div class="snow-errors">
      <% @budget_rule.errors.full_messages.each do |msg| %>
        <span><%= msg %></span>
      <% end %>
    </div>
  <% end %>

  <div class="snow-panel">
    <div class="snow-stack">
      <% fields = [
           [:salary_target_cents,    "Salaire mensuel cible SAS → EI (€)", "Entrez le montant en euros"],
           [:mortgage_amount_cents,  "Remboursement crédit immo mensuel (€)", nil],
           [:living_expenses_cents,  "Train de vie mensuel (€)", nil],
           [:savings_target_cents,   "Épargne mensuelle cible (€)", nil],
           [:freelance_budget_cents, "Budget freelance mensuel (€)", nil]
         ] %>
      <% fields.each do |attr, label, hint| %>
        <div class="snow-field">
          <%= f.label attr, label %>
          <%= f.number_field attr, value: @budget_rule.public_send(attr).to_i / 100, step: 1, min: 0, class: "snow-input" %>
          <% if hint %><span class="hint"><%= hint %></span><% end %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="snow-form-actions">
    <%= f.submit "Enregistrer", class: "snow-btn snow-btn--ink" %>
    <%= link_to "Annuler", root_path, class: "snow-btn" %>
  </div>
<% end %>
