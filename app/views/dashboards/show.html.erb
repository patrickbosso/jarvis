<div class="space-y-8">
  <h1 class="text-3xl font-bold text-white">Bonjour, Baptiste 👋</h1>

  <%# Zone 1 — Studio %>
  <section>
    <h2 class="text-lg font-semibold text-gray-400 uppercase tracking-wider mb-4">Studio</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
      <div class="bg-gray-900 rounded-xl p-5 border border-gray-800">
        <p class="text-sm text-gray-400 mb-1">CA du mois</p>
        <p class="text-2xl font-bold text-green-400"><%= number_to_currency(@ca_month / 100.0, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %></p>
      </div>
      <div class="bg-gray-900 rounded-xl p-5 border border-gray-800">
        <p class="text-sm text-gray-400 mb-1">CA prévisionnel</p>
        <p class="text-2xl font-bold text-blue-400"><%= number_to_currency(@ca_previsionnel / 100.0, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %></p>
      </div>
      <div class="bg-gray-900 rounded-xl p-5 border border-gray-800">
        <p class="text-sm text-gray-400 mb-1">Factures en retard</p>
        <p class="text-2xl font-bold <%= @ca_overdue > 0 ? 'text-red-400' : 'text-gray-500' %>">
          <%= number_to_currency(@ca_overdue / 100.0, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %>
        </p>
        <% if @invoices_overdue.any? %>
          <span class="text-xs text-red-400"><%= @invoices_overdue.count %> facture(s)</span>
        <% end %>
      </div>
    </div>

    <div class="bg-gray-900 rounded-xl border border-gray-800 overflow-hidden">
      <div class="px-5 py-3 border-b border-gray-800">
        <h3 class="font-medium text-gray-200">Projets en cours</h3>
      </div>
      <% if @projects_active.any? %>
        <ul class="divide-y divide-gray-800">
          <% @projects_active.each do |project| %>
            <li class="px-5 py-3 flex items-center justify-between">
              <div>
                <p class="font-medium text-white"><%= project.title %></p>
                <p class="text-sm text-gray-400"><%= project.client_name %></p>
              </div>
              <span class="inline-block px-2 py-1 rounded-full text-xs font-medium <%= status_badge_class(project.status) %>">
                <%= project.current_step.presence || project.status.humanize %>
              </span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="px-5 py-4 text-gray-500 text-sm">Aucun projet actif.</p>
      <% end %>
    </div>
  </section>

  <%# Zone 2 — Finances %>
  <section>
    <h2 class="text-lg font-semibold text-gray-400 uppercase tracking-wider mb-4">Finances</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="bg-gray-900 rounded-xl p-5 border border-gray-800">
        <p class="text-sm text-gray-400 mb-1">Qonto SAS</p>
        <% if @qonto %>
          <p class="text-2xl font-bold text-white"><%= number_to_currency(@qonto.balance_cents / 100.0, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %></p>
          <p class="text-xs text-gray-500 mt-1">Mis à jour il y a <%= time_ago_in_words(@qonto.fetched_at) %></p>
        <% else %>
          <p class="text-gray-500 text-sm">Non connecté</p>
        <% end %>
      </div>

      <div class="bg-gray-900 rounded-xl p-5 border border-gray-800">
        <p class="text-sm text-gray-400 mb-1">Compte perso SG</p>
        <% if @sg_perso %>
          <p class="text-2xl font-bold text-white"><%= number_to_currency(@sg_perso.balance_cents / 100.0, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %></p>
          <p class="text-xs text-gray-500 mt-1">Mis à jour il y a <%= time_ago_in_words(@sg_perso.fetched_at) %></p>
        <% else %>
          <p class="text-gray-500 text-sm">Non connecté</p>
        <% end %>
      </div>

      <div class="bg-gray-900 rounded-xl p-5 border border-gray-800">
        <p class="text-sm text-gray-400 mb-1">PEA Trade Republic</p>
        <% if @pea %>
          <p class="text-2xl font-bold text-white"><%= number_to_currency(@pea.balance_cents / 100.0, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %></p>
          <p class="text-xs text-gray-500 mt-1">Mis à jour il y a <%= time_ago_in_words(@pea.fetched_at) %></p>
        <% else %>
          <p class="text-gray-500 text-sm">Non connecté</p>
        <% end %>
      </div>
    </div>

    <% if @budget_rule %>
      <div class="mt-4 bg-gray-900 rounded-xl p-5 border border-gray-800 inline-block">
        <p class="text-sm text-gray-400 mb-1">Crédit immo mensuel</p>
        <p class="text-xl font-bold text-white"><%= number_to_currency(@budget_rule.mortgage_amount_cents / 100.0, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %></p>
      </div>
    <% end %>
  </section>

  <%# Zone 3 — Jarvis %>
  <section>
    <h2 class="text-lg font-semibold text-gray-400 uppercase tracking-wider mb-4">Jarvis — Suggestions du jour</h2>

    <% if @suggestion %>
      <div class="bg-gray-900 rounded-xl border border-indigo-800 p-6">
        <p class="text-gray-300 mb-4">Voici les virements suggérés basés sur ton solde actuel :</p>

        <ul class="space-y-3 mb-6">
          <% @suggestion.transfers.each do |transfer| %>
            <li class="flex items-center justify-between bg-gray-800 rounded-lg px-4 py-3">
              <span class="text-gray-200"><%= transfer["label"] %></span>
              <span class="font-bold text-white"><%= number_to_currency(transfer["amount_cents"].to_i / 100.0, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %></span>
            </li>
          <% end %>
        </ul>

        <div class="flex gap-3">
          <%= button_to "✓ Valider", transfer_suggestion_path(@suggestion), method: :patch, params: { action_type: "validate" }, class: "px-5 py-2 bg-indigo-600 hover:bg-indigo-500 text-white rounded-lg font-medium transition cursor-pointer" %>
          <%= button_to "Ignorer", transfer_suggestion_path(@suggestion), method: :patch, params: { action_type: "dismiss" }, class: "px-5 py-2 bg-gray-700 hover:bg-gray-600 text-gray-200 rounded-lg font-medium transition cursor-pointer" %>
        </div>
      </div>
    <% else %>
      <div class="bg-gray-900 rounded-xl border border-gray-800 p-6 text-center">
        <p class="text-gray-500">Aucune suggestion en attente.</p>
        <% unless @budget_rule %>
          <p class="text-sm text-yellow-400 mt-2">
            <%= link_to "Configurez vos règles budgétaires", edit_budget_rule_path, class: "underline" %> pour recevoir des suggestions.
          </p>
        <% end %>
      </div>
    <% end %>
  </section>
</div>
