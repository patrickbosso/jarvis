<!DOCTYPE html>
<html class="h-full bg-gray-950">
  <head>
    <title>Jarvis</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full text-gray-100 font-sans">
    <% if user_signed_in? %>
      <nav class="bg-gray-900 border-b border-gray-800 px-6 py-4 flex items-center justify-between">
        <span class="text-xl font-bold tracking-tight text-white">⚡ Jarvis</span>
        <div class="flex items-center gap-4 text-sm">
          <%= link_to "Dashboard", root_path, class: "text-gray-400 hover:text-white transition" %>
          <%= link_to "Règles budget", edit_budget_rule_path, class: "text-gray-400 hover:text-white transition" %>
          <%= link_to "Historique", transfer_suggestions_path, class: "text-gray-400 hover:text-white transition" %>
          <%= link_to "Déconnexion", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-gray-400 hover:text-white transition" %>
        </div>
      </nav>
    <% end %>

    <% if notice.present? %>
      <div class="bg-green-900 border border-green-700 text-green-100 px-6 py-3 text-sm">
        <%= notice %>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="bg-red-900 border border-red-700 text-red-100 px-6 py-3 text-sm">
        <%= alert %>
      </div>
    <% end %>

    <main class="max-w-7xl mx-auto px-6 py-8">
      <%= yield %>
    </main>
  </body>
</html>
