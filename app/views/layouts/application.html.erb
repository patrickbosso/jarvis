<!DOCTYPE html>
<html class="h-full">
  <head>
    <title>Jarvis — Baptiste Fournier</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full">
    <% if user_signed_in? %>
      <% has_rail = content_for?(:rail) %>
      <div class="snow-shell<%= ' no-rail' unless has_rail %>">

        <%# ---------- Left sidebar ---------- %>
        <aside class="snow-sidebar">
          <div class="snow-brand">
            <span class="avatar">𝔅</span>
            <span>Jarvis</span>
          </div>

          <div class="snow-tabs">
            <span class="snow-tab">Favoris</span>
            <span class="snow-tab active">Récents</span>
          </div>

          <div class="snow-navgroup-title">Tableaux de bord</div>
          <nav class="snow-nav">
            <%= link_to root_path, class: "snow-nav-item #{'active' if current_page?(root_path)}" do %>
              <span class="ic">◧</span><span>Vue d'ensemble</span>
            <% end %>
            <%= link_to transfer_suggestions_path, class: "snow-nav-item #{'active' if current_page?(transfer_suggestions_path)}" do %>
              <span class="ic">↻</span><span>Suggestions</span>
            <% end %>
          </nav>

          <div class="snow-navgroup-title">Réglages</div>
          <nav class="snow-nav">
            <%= link_to edit_budget_rule_path, class: "snow-nav-item #{'active' if current_page?(edit_budget_rule_path)}" do %>
              <span class="ic">▤</span><span>Budget</span>
            <% end %>
            <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "snow-nav-item" do %>
              <span class="ic">⏻</span><span>Déconnexion</span>
            <% end %>
          </nav>
        </aside>

        <%# ---------- Main column ---------- %>
        <div class="snow-main">
          <header class="snow-topbar">
            <div class="snow-breadcrumb">
              <span class="ic">◧</span>
              <span>Tableaux de bord</span>
              <span>/</span>
              <span class="cur"><%= content_for?(:breadcrumb) ? yield(:breadcrumb) : "Vue d'ensemble" %></span>
            </div>
            <div style="display:flex; align-items:center; gap:16px;">
              <label class="snow-search">
                <span>⌕</span>
                <input type="text" placeholder="Rechercher" disabled>
              </label>
              <div class="snow-topbar-actions">
                <span class="ic" title="Notifications">◔</span>
                <span class="ic" title="Aujourd'hui"><%= l(Date.today, format: "%d %b") %></span>
              </div>
            </div>
          </header>

          <% if notice.present? %><div class="snow-flash notice"><%= notice %></div><% end %>
          <% if alert.present? %><div class="snow-flash alert"><%= alert %></div><% end %>

          <div class="snow-content">
            <%= yield %>
          </div>
        </div>

        <%# ---------- Right rail ---------- %>
        <% if has_rail %>
          <aside class="snow-rail"><%= yield :rail %></aside>
        <% end %>
      </div>
    <% else %>
      <main style="max-width: 28rem; margin: 0 auto; padding: 4rem 2rem;">
        <% if notice.present? %><div class="snow-flash notice"><%= notice %></div><% end %>
        <% if alert.present? %><div class="snow-flash alert"><%= alert %></div><% end %>
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
