<div>
  <h1 class="text-2xl font-bold text-white mb-6">Historique des suggestions</h1>

  <% if @suggestions.any? %>
    <div class="space-y-4">
      <% @suggestions.each do |suggestion| %>
        <div class="bg-gray-900 rounded-xl border border-gray-800 p-5">
          <div class="flex items-center justify-between mb-3">
            <span class="text-sm text-gray-400"><%= l suggestion.suggested_at, format: :long rescue suggestion.suggested_at.strftime("%d/%m/%Y à %Hh%M") %></span>
            <span class="inline-block px-2 py-1 rounded-full text-xs font-medium <%= suggestion_status_class(suggestion.status) %>">
              <%= suggestion.status.humanize %>
            </span>
          </div>
          <ul class="space-y-2">
            <% suggestion.transfers.each do |t| %>
              <li class="flex justify-between text-sm">
                <span class="text-gray-300"><%= t["label"] %></span>
                <span class="font-medium text-white"><%= number_to_currency(t["amount_cents"].to_i / 100.0, unit: "€", separator: ",", delimiter: " ", format: "%n %u") %></span>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-gray-900 rounded-xl border border-gray-800 p-8 text-center">
      <p class="text-gray-500">Aucune suggestion pour le moment.</p>
    </div>
  <% end %>
</div>
