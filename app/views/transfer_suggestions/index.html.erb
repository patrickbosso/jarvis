<% content_for :breadcrumb, "Suggestions" %>

<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
  <h1 class="snow-page-title" style="margin:0;">Historique des suggestions</h1>
  <span style="font-size:12px; color:var(--ink-40);"><%= @suggestions.count %></span>
</div>

<% if @suggestions.any? %>
  <div class="snow-stack">
    <% @suggestions.each do |suggestion| %>
      <div class="snow-panel">
        <div class="snow-panel-head" style="margin-bottom:14px;">
          <span style="font-size:13px; color:var(--ink-40);">
            <%= l suggestion.suggested_at, format: :long rescue suggestion.suggested_at.strftime("%d/%m/%Y à %Hh%M") %>
          </span>
          <span class="snow-badge <%= suggestion.status %>"><%= suggestion.status.humanize %></span>
        </div>
        <div style="display:flex; flex-direction:column; gap:12px;">
          <% suggestion.transfers.each do |t| %>
            <div class="snow-list-row">
              <span class="k"><%= t["label"] %></span>
              <span class="v"><%= eur(t["amount_cents"]) %></span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="snow-panel" style="text-align:center; padding:40px;">
    <p style="font-size:13px; color:var(--ink-40);">Aucune suggestion pour le moment.</p>
  </div>
<% end %>
